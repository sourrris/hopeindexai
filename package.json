{
  "name": "hopeindexai",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "bun build src/app.jsx --outfile=public/app.js --target=browser --production",
    "dev": "bun run build && bun --watch server.ts",
    "start": "bun server.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test tests/*.test.ts",
    "test:vercel": "bun test-handler.mjs"
  },
  "dependencies": {
    "hono": "^4",
    "leaflet": "1.9.4",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
