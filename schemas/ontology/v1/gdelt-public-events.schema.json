{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hopeindex.ai/schemas/ontology/v1/gdelt-public-events.schema.json",
  "title": "HopeIndexAI Public GDELT Event Slice",
  "type": "object",
  "additionalProperties": false,
  "required": ["events", "count", "updated"],
  "properties": {
    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/GdeltEventRow" }
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "updated": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "GdeltEventRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "lat",
        "lon",
        "category",
        "theme",
        "hopeScore",
        "goldstein",
        "quadClass",
        "quadLabel",
        "actor1",
        "actor2",
        "country",
        "location",
        "date",
        "numMentions",
        "avgTone",
        "sourceUrl",
        "markerRadius",
        "severity",
        "continent"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lon": { "type": "number", "minimum": -180, "maximum": 180 },
        "category": { "type": "string", "enum": ["doom", "bloom"] },
        "theme": {
          "type": "string",
          "enum": ["Diplomacy", "Conflict", "Econ", "Environment", "Humanitarian", "Science"]
        },
        "hopeScore": { "type": "integer", "minimum": 0, "maximum": 100 },
        "aiSummary": { "type": "string" },
        "aiReasoning": { "type": "string" },
        "goldstein": { "type": ["number", "null"] },
        "quadClass": { "type": ["integer", "null"], "minimum": 1, "maximum": 4 },
        "quadLabel": { "type": "string", "minLength": 1 },
        "actor1": { "type": "string", "minLength": 1 },
        "actor2": { "type": "string", "minLength": 1 },
        "country": { "type": "string" },
        "location": { "type": "string" },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "numMentions": { "type": "integer", "minimum": 0 },
        "avgTone": { "type": ["number", "null"] },
        "sourceUrl": { "type": "string" },
        "markerRadius": { "type": "number", "minimum": 0 },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "continent": {
          "type": "string",
          "enum": ["Americas", "Europe", "Middle East", "Africa", "Asia", "Oceania", "Other"]
        }
      }
    }
  }
}
